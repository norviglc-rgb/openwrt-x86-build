# ============================================================
# OpenWrt x86-64 编译配置
# 基于 OpenWrt 23.05 / Lean's LEDE
# 目标: 高性能软路由 (4核8线程 + 8GB 内存)
# ============================================================

# ===========================================
# 目标系统配置
# ===========================================
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# ===========================================
# 镜像配置
# ===========================================
# EFI 启动支持
CONFIG_GRUB_EFI_IMAGES=y
CONFIG_GRUB_BOOTSIGNATURE=y
CONFIG_GRUB_PARTITION_GPT=y

# 文件系统 (squashfs 支持系统还原)
CONFIG_TARGET_ROOTFS_SQUASHFS=y
# CONFIG_TARGET_ROOTFS_EXT4FS=y

# rootfs 大小 (MB), ext4 时有效
# CONFIG_TARGET_ROOTFS_PARTSIZE=512

# ===========================================
# 内核模块 - 网络驱动
# ===========================================
# Intel 网卡
CONFIG_PACKAGE_kmod-e1000e=y
CONFIG_PACKAGE_kmod-igb=y
CONFIG_PACKAGE_kmod-ixgbe=y
CONFIG_PACKAGE_kmod-i40e=y

# Realtek 网卡
CONFIG_PACKAGE_kmod-r8169=y

# VirtIO 虚拟化
CONFIG_PACKAGE_kmod-virtio-net=y
CONFIG_PACKAGE_kmod-virtio-pci=y
CONFIG_PACKAGE_kmod-virtio-blk=y

# ===========================================
# 内核模块 - 存储驱动
# ===========================================
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-scsi-core=y
CONFIG_PACKAGE_kmod-ata-core=y
CONFIG_PACKAGE_kmod-ata-ahci=y
CONFIG_PACKAGE_kmod-nvme=y

# ===========================================
# 内核模块 - 文件系统
# ===========================================
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-f2fs=y

# ===========================================
# 内核模块 - 网络核心
# ===========================================
CONFIG_PACKAGE_kmod-ipv6=y
CONFIG_PACKAGE_kmod-ipt-core=y
CONFIG_PACKAGE_kmod-ipt-extra=y
CONFIG_PACKAGE_kmod-ipt-conntrack=y
CONFIG_PACKAGE_kmod-ipt-conntrack-extra=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-ipt-nat6=y
CONFIG_PACKAGE_kmod-ipt-tproxy=y
CONFIG_PACKAGE_kmod-ipt-ipset=y
CONFIG_PACKAGE_kmod-ipt-filter=y
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-nat=y

# TUN/TAP (代理必需)
CONFIG_PACKAGE_kmod-tun=y

# ===========================================
# 系统基础包
# ===========================================
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_cfdisk=y
CONFIG_PACKAGE_losetup=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_mkf2fs=y
CONFIG_PACKAGE_ntfs-3g=y
CONFIG_PACKAGE_exfat-fsck=y

# ===========================================
# Web 服务器 - Nginx
# ===========================================
CONFIG_PACKAGE_nginx-ssl=y
CONFIG_PACKAGE_nginx-mod-luci=y
CONFIG_PACKAGE_libnginx-http-ssl=y

# ===========================================
# LuCI Web 界面
# ===========================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y

# 中文语言包
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ddns-zh-cn=y

# ===========================================
# DNS/DHCP
# ===========================================
CONFIG_PACKAGE_dnsmasq-full=y
# CONFIG_PACKAGE_dnsmasq is not set

# ===========================================
# 防火墙
# ===========================================
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_iptables-legacy=y
CONFIG_PACKAGE_iptables-mod-extra=y
CONFIG_PACKAGE_iptables-mod-tproxy=y
CONFIG_PACKAGE_ip6tables-nft=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_conntrack=y

# ===========================================
# 网络工具
# ===========================================
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_ethtool=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_mtr=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_nmap=y

# ===========================================
# 系统工具
# ===========================================
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_btop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_vim-full=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_tar=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_xz=y
CONFIG_PACKAGE_zstd=y
CONFIG_PACKAGE_lrzsz=y
CONFIG_PACKAGE_screen=y
CONFIG_PACKAGE_tmux=y

# ===========================================
# 基础 LuCI 应用
# ===========================================
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-app-sqm=y

# ===========================================
# 存储管理
# ===========================================
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_autopart=y
CONFIG_PACKAGE_automount=y

# ===========================================
# 监控插件
# ===========================================
CONFIG_PACKAGE_luci-app-netdata=y
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_luci-app-statistics=y

# ===========================================
# 安全插件
# ===========================================
CONFIG_PACKAGE_luci-app-banip=y
CONFIG_PACKAGE_luci-app-oaf=y
CONFIG_PACKAGE_kmod-oaf=y

# ===========================================
# 访问控制
# ===========================================
CONFIG_PACKAGE_luci-app-accesscontrol=y

# ===========================================
# 网络服务
# ===========================================
# CONFIG_PACKAGE_luci-app-mwan3 is not set  # 已移除多拨
# CONFIG_PACKAGE_luci-app-p910nd is not set # 已移除打印
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-app-timewol=y
CONFIG_PACKAGE_luci-app-watchcat=y

# ===========================================
# 推送通知
# ===========================================
CONFIG_PACKAGE_luci-app-wechatpush=y

# ===========================================
# 证书管理
# ===========================================
CONFIG_PACKAGE_luci-app-acme=y
CONFIG_PACKAGE_acme=y
CONFIG_PACKAGE_px5g=y

# ===========================================
# QoS - 智能流量控制
# ===========================================
CONFIG_PACKAGE_luci-app-sqm-autorate=y
CONFIG_PACKAGE_kmod-sched-cake=y
CONFIG_PACKAGE_kmod-sched-fq-codel=y
CONFIG_PACKAGE_tc-full=y

# ===========================================
# 编译优化
# ===========================================
CONFIG_CCACHE=y
CONFIG_DEVEL=y
# CONFIG_DEBUG is not set

# ===========================================
# 其他优化
# ===========================================
CONFIG_OPTIMIZE_FOR_SPEED=y
